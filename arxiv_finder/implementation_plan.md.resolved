    """通过 arXiv 网页搜索和下载论文（来自 chat_arxiv.py）"""
    def search(self, query, page_num, days, max_results) -> list[Paper]: ...

class ArxivAPICrawler:
    """通过 arXiv API 搜索和下载论文（来自 chat_paper.py）"""
    def search(self, query, sort, max_results, filter_keys) -> list[Paper]: ...
```

- 将 `Reader.get_url`, [get_titles](file:///f:/claude/ChatPaper/chat_arxiv.py#381-412), [get_all_titles_from_web](file:///f:/claude/ChatPaper/chat_arxiv.py#414-428), [get_arxiv_web](file:///f:/claude/ChatPaper/chat_arxiv.py#429-444), [download_pdf](file:///f:/claude/ChatPaper/chat_arxiv.py#451-463) 提取到 `ArxivWebCrawler`
