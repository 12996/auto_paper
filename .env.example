# LLM provider: local | deepseek | gemini | custom
# - local/custom: use ARXIV_API_BASE/ARXIV_API_KEY/ARXIV_MODEL
# - deepseek: use ARXIV_DEEPSEEK_*
# - gemini: use ARXIV_GEMINI_*
ARXIV_LLM_PROVIDER=deepseek

# Local / custom OpenAI-compatible endpoint (e.g. local gateway)
ARXIV_API_BASE=http://127.0.0.1:8317/v1
ARXIV_API_KEY=
ARXIV_MODEL=gpt-5

# DeepSeek
ARXIV_DEEPSEEK_API_BASE=https://api.deepseek.com/v1
ARXIV_DEEPSEEK_API_KEY=
ARXIV_DEEPSEEK_MODEL=deepseek-chat

# Gemini OpenAI-compatible endpoint
ARXIV_GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
ARXIV_GEMINI_API_KEY=
ARXIV_GEMINI_MODEL=gemini-2.5-pro
